{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": ".",
    "types": ["node"],
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false
  },
  "include": [
    "src/plugin/dashboard/spa/**/*.ts",
    "src/plugin/dashboard/spa/**/*.tsx",
    "tests/unit/dashboard-spa.test.tsx",
    "tests/unit/dashboard-config-tabs.test.tsx"
  ],
  "exclude": ["node_modules", "dist"]
}
